{
  "name": "papercode",
  "version": "0.1.1",
  "bin": {
    "papercode": "./bin/papercode.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opentui/core": "^0.3.1",
    "@pierre/diffs": "^1.2.7",
    "opentui-spinner": "^0.0.6",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0"
  },
  "scripts": {
    "dev:cli": "bun run --watch packages/cli/src/index.tsx",
    "dev:server": "bun run --hot packages/server/src/index.ts",
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run build"
  },
  "workspaces": [
    "packages/*"
  ]
}
