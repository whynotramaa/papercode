{
  "name": "papercode",
  "version": "0.1.0",
  "description": "A terminal coding agent that works with any OpenAI-compatible provider.",
  "type": "module",
  "bin": {
    "papercode": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "clipboardy": "^4.0.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "ink": "^5.1.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.1.0",
    "openai": "^6.48.0",
    "react": "^18.3.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.3"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
